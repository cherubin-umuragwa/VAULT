rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 0.2 Context-Aware Helpers
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Profile Security
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
                    && isValidId(userId)
                    && incoming().userId == userId
                    && incoming().email is string
                    && (incoming().dailyIncome == null || incoming().dailyIncome is number)
                    && (incoming().displayName == null || incoming().displayName is string)
                    && (incoming().photoURL == null || incoming().photoURL is string)
                    && (incoming().updatedAt == null || incoming().updatedAt is string);
      allow update: if isOwner(userId)
                    && incoming().userId == userId
                    && incoming().email == existing().email
                    && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'savingsMethod', 'dailyIncome', 'updatedAt']);
      
      // Subcollectons
      match /goals/{goalId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) 
                      && isValidId(goalId)
                      && incoming().userId == userId
                      && incoming().targetAmount is number
                      && incoming().currentAmount is number;
        allow update: if isOwner(userId)
                      && incoming().userId == userId
                      && incoming().targetAmount == existing().targetAmount
                      && incoming().diff(existing()).affectedKeys().hasAny(['currentAmount', 'status', 'title', 'deadline']);
        allow delete: if isOwner(userId);
      }

      match /expenses/{expenseId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(expenseId) && incoming().userId == userId;
        allow update, delete: if isOwner(userId);
      }

      match /subscriptions/{subId} {
        allow list, get: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }

      match /debts/{debtId} {
        allow list, get: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }

      match /chats/{chatId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(chatId) && incoming().userId == userId;
        allow update, delete: if isOwner(userId);
      }
    }
  }
}
